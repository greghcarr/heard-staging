# Secrets injected into the Heard edge function when served locally.
#
# SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are provided
# automatically by `supabase functions serve`, so they are intentionally absent.
#
# HEARD_API_SECRET must match VITE_HEARD_API_SECRET in Heard's .env.local.

HEARD_API_SECRET=heard-local-dev-secret
DEV_ADMIN_KEY=heard-local-admin
CRON_SECRET=heard-local-cron
FRONTEND_URL=http://localhost:5173

# External providers — left blank so staging never sends real email/SMS or
# spends on LLM calls. Code paths that need them will no-op or error loudly;
# fill any in if you need to exercise that feature against a real provider.
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PHONE_NUMBER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ASSEMBLYAI_API_KEY=
